\@writefile{toc}{\contentsline {section}{\numberline {VIII}Visual Comparison of the Models}{4}{section.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces RMSE and MAE comparison across train, validation, and test splits. These plots show that ensemble trees reduce error substantially compared with the baseline and the linear models.}}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:error-main}{{2}{4}{RMSE and MAE comparison across train, validation, and test splits. These plots show that ensemble trees reduce error substantially compared with the baseline and the linear models}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Overview of the most important comparison dimensions. The figure highlights that Gradient Boosting is strongest on validation, while Random Forest is strongest on the held-out test set.}}{5}{figure.caption.2}\protected@file@percent }
\newlabel{fig:overview}{{1}{5}{Overview of the most important comparison dimensions. The figure highlights that Gradient Boosting is strongest on validation, while Random Forest is strongest on the held-out test set}{figure.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces $R^2$ and explained variance comparison. The same pattern appears in both views: the ensemble models explain the largest share of the target variation.}}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:variance-metrics}{{3}{5}{$R^2$ and explained variance comparison. The same pattern appears in both views: the ensemble models explain the largest share of the target variation}{figure.caption.4}{}}
