\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces MAPE and median absolute error. These metrics support the same overall conclusion, while also showing that some models differ in how stable their typical errors are.}}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:robust-metrics}{{4}{5}{MAPE and median absolute error. These metrics support the same overall conclusion, while also showing that some models differ in how stable their typical errors are}{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Ranking by validation RMSE and test RMSE. Gradient Boosting wins the validation phase, but Random Forest becomes the best model on the final test set.}}{6}{figure.caption.6}\protected@file@percent }
\newlabel{fig:rmse-rankings}{{5}{6}{Ranking by validation RMSE and test RMSE. Gradient Boosting wins the validation phase, but Random Forest becomes the best model on the final test set}{figure.caption.6}{}}
